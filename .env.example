# ---------------------------------------------------------------------------
# Aggressive Trading Bot — environment configuration template
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# ---------------------------------------------------------------------------

# --- Runtime -----------------------------------------------------------------
APP_ENV=local                 # local | dev | prod
LOG_LEVEL=INFO                # DEBUG | INFO | WARNING | ERROR
LOG_JSON=false                # true = JSON logs (prod), false = console (dev)

# --- Operating mode ----------------------------------------------------------
# research | paper | approval | automation
# `automation` is intentionally gated and disabled by hard kill-switch below.
TRADING_MODE=research
AUTOMATION_ENABLED=false      # Master kill-switch. Must be true AND mode=automation.

# --- Scheduler ---------------------------------------------------------------
# Baseline research-scan cadence in minutes. Default 180 (every 3 hours). The
# scanner is not yet market-session-aware and runs 24/7, so a slow baseline
# keeps closed-market API waste low. Session-aware per-tier cadences land later.
SCAN_INTERVAL_MINUTES=180

# --- Event bus + change detection --------------------------------------------
EVENTS_ENABLED=true            # run change detectors each scan, publish to bus
PRICE_CHANGE_THRESHOLD_PCT=1.0 # min % move to emit PriceChanged
FLOW_BURST_PREMIUM_USD=250000  # min fresh premium to emit FlowDetected

# --- Account / risk policy ---------------------------------------------------
# Default = "aggressive but defined-risk": 5%/trade, 15% account. A $2k account
# cannot size mega-cap spreads at 2% ($40); tighten only if you also switch to a
# lower-priced universe. See docs/RISK_POLICY.md.
ACCOUNT_EQUITY_USD=2000
MAX_ACCOUNT_RISK_PCT=0.15     # Max % of equity at risk across all open trades
MAX_TRADE_RISK_PCT=0.05       # Max % of equity at risk in a single trade
MAX_CONCURRENT_POSITIONS=4
MAX_DEFINED_RISK_PER_TRADE_USD=100
MAX_CONTRACTS_PER_TRADE=20     # concentration / fill-risk cap on lot count

# --- Database ----------------------------------------------------------------
# Durable backend is Turso / libSQL (cloud SQLite). Set these two and the app
# stores everything there (highest precedence). The token is a secret — keep it
# in your gitignored .env, never commit it.
# TURSO_DATABASE_URL=libsql://<your-db>.turso.io
# TURSO_AUTH_TOKEN=<your-turso-auth-token>

# Fallbacks (used only when TURSO_* is unset):
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=atb
POSTGRES_USER=atb
POSTGRES_PASSWORD=change_me
# Optional full DSN override (takes precedence over Postgres, below Turso):
# DATABASE_URL=postgresql+psycopg://atb:change_me@localhost:5432/atb

# --- Redis -------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# --- Provider efficiency (caching + rate limiting) ---------------------------
CACHE_ENABLED=true             # cache read-only provider responses (per-type TTL)
CACHE_BACKEND=memory           # memory | redis  (redis falls back to memory if down)
CACHE_TTL_SCALE=1.0            # global multiplier on all cache TTLs
RATE_LIMIT_ENABLED=true        # proactive per-provider token bucket
RATE_LIMIT_DEFAULT_RPM=120     # req/min fallback for providers without a preset
API_BUDGET_ENABLED=false       # opt-in hard daily request cap per provider
API_DAILY_BUDGET=10000         # per-provider daily cap when API_BUDGET_ENABLED

# --- Alerts ------------------------------------------------------------------
ALERTS_ENABLED=false           # master switch; default off
ALERTS_CHANNEL=console         # console | slack | noop
ALERTS_MIN_SCORE=0.6           # only alert on actionable candidates >= this score
SLACK_WEBHOOK_URL=             # required when ALERTS_CHANNEL=slack

# --- Data providers ----------------------------------------------------------
# Which provider implementation each capability resolves to.
# Options: mock | fmp | unusual_whales | robinhood
PROVIDER_MARKET_DATA=mock
PROVIDER_OPTIONS_FLOW=mock
PROVIDER_OPTIONS_CHAIN=mock
PROVIDER_FUNDAMENTALS=mock
PROVIDER_CALENDAR=mock
PROVIDER_BROKERAGE=mock
# IV history for computing IV rank/percentile. Leave empty to fall back to a
# realized-vol proxy from real price history. unusual_whales implements it via
# GET /api/stock/{ticker}/iv-rank.
PROVIDER_IV_HISTORY=mock

# --- Financial Modeling Prep -------------------------------------------------
# Confirm tier/endpoints against official docs before enabling. See
# docs/providers/FINANCIAL_MODELING_PREP.md
FMP_API_KEY=
FMP_BASE_URL=https://financialmodelingprep.com

# --- Unusual Whales ----------------------------------------------------------
# API access is a paid add-on. Confirm endpoints/licensing before enabling.
# See docs/providers/UNUSUAL_WHALES.md
UNUSUAL_WHALES_API_KEY=
UNUSUAL_WHALES_BASE_URL=https://api.unusualwhales.com

# --- Robinhood ---------------------------------------------------------------
# Used for account/positions/market data. Treat credentials as highly sensitive.
# See docs/providers/ROBINHOOD.md
ROBINHOOD_USERNAME=
ROBINHOOD_PASSWORD=
ROBINHOOD_MFA_SECRET=
